# EHR Media Intelligence — environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Anthropic API key used for clinical summarization.
# Obtain one at https://console.anthropic.com/. Leave empty to disable
# summarization features in local development. Cached summaries can still be
# read without a key.
ANTHROPIC_API_KEY=

# Anthropic model used for clinical summarization. Configurable; the value
# below is an example, not a hardcoded default in application logic.
ANTHROPIC_MODEL=claude-sonnet-5

# SQLAlchemy database URL for application persistence (records, audit log,
# summary cache). SQLite is the supported backend.
DATABASE_URL=sqlite:///./data/ehr.sqlite3

# Filesystem path where ChromaDB persists vector embeddings.
CHROMA_PATH=./data/chroma

# ChromaDB collection name for the semantic search index.
CHROMA_COLLECTION=ehr_media

# Sentence-transformers model used to embed clinical text for semantic search.
# Configurable; the value below is the project default.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Comma-separated list of origins allowed to call the API (CORS).
# Use the Vite dev server origin during local development.
CORS_ORIGINS=http://localhost:5173

# Frontend: base URL of the FastAPI backend, read by the Vite app at build time.
# Defaults to the local FastAPI dev server when unset.
VITE_API_BASE_URL=http://127.0.0.1:8000
